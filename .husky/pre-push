#!/usr/bin/env sh
# pre-push — heavier CI-parity gates that don't fit in pre-commit's
# interactive budget. The fast/medium CI gates (typecheck, build, lint,
# size, vendor-manifest) already ran in .husky/pre-commit; this hook
# adds the network-adjacent gates that need npm install / fixture
# builds before the push lands.
#
# Escape hatches:
#   - `SKIP_PREPUSH=1 git push ...`    — skip the hook body entirely.
#   - `git push --no-verify`           — git-native bypass.
#
# ─── CI ↔ pre-push parity ────────────────────────────────────────────
#
# Workflow                              Job(s) mirrored here
# ─────────────────────────────────────  ─────────────────────────────
# wasm.yml :: bundler-interop matrix    e2e/bundler-interop/{webpack5,
#                                       vite5,esbuild}-app: install +
#                                       build + verify (bundle-no-
#                                       wasm-leak invariant per #689).
#
# NOT mirrored locally (require non-pnpm toolchains; CI gate remains
# authoritative):
#   - wasm.yml cargo-check + wasm-pack matrix  — needs Rust + wasm-pack
#                                                 + binaryen 119
#   - four-way-classifier.yml                  — needs Rust + cargo
#   - cross-backend-fuzz.yml                   — nightly cron only
#
# Tests are NOT mirrored here: the active CI lanes (main-fast,
# bundle-budget, vendor-manifest) do not include `pnpm test:run`.
# Tests live in `pnpm validate` for local manual use and in the
# heavier release-lane verification that runs before publish.

if [ "${SKIP_PREPUSH:-0}" = "1" ]; then
  echo "pre-push: SKIP_PREPUSH=1 set — skipping all hooks"
  exit 0
fi

set -e

# bundler-interop — mirrors wasm.yml's bundler-interop matrix
# (webpack5-app, vite5-app, esbuild-app). The matrix legs each
# `npm install --no-save` their deps from outside the pnpm
# workspace (by design — fixtures must consume @causl/core the
# way an external adopter would), then build, then verify the
# bundle-no-wasm-leak invariant via `node verify.mjs`.
#
# Each leg costs ~15-30s wall-clock on first install (npm cache
# warmups thereafter). Use SKIP_PREPUSH=1 if pushing a docs-only
# or non-bundle-affecting change.
if [ -d e2e/bundler-interop ]; then
  echo "pre-push: building @causl/core (required by bundler-interop fixtures)"
  pnpm --filter @causl/core run build

  echo "pre-push: stubbing wasm-pkg artefacts (matches wasm.yml step)"
  node e2e/bundler-interop/stub-wasm-pkg.mjs

  for fixture in webpack5-app vite5-app esbuild-app; do
    dir="e2e/bundler-interop/$fixture"
    if [ ! -d "$dir" ]; then
      echo "pre-push: $dir absent — skipping"
      continue
    fi
    echo "pre-push: bundler-interop ($fixture) — npm install + build + verify"
    (cd "$dir" && npm install --no-save --no-audit --no-fund && npm run build && npm run verify)
  done
else
  echo "pre-push: e2e/bundler-interop/ absent — nothing to do"
fi

echo "pre-push: all gates green ✓"
