{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "useUnknownInCatchVariables": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@causljs/core": ["./packages/core/src/index.ts"],
      "@causljs/core/internal": ["./packages/core/src/internal.ts"],
      "@causljs/core/testing": ["./packages/core/testing/src/index.ts"],
      "@causljs/core/wasm": ["./packages/core/wasm/index.ts"],
      "@causljs/formula": ["./packages/formula/src/index.ts"],
      "@causljs/sync": ["./packages/sync/src/index.ts"]
    }
  }
}
